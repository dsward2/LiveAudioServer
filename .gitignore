xcuserdata/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/

# SwiftPM/Xcode generated
/.swiftpm

# Misc
.netrc

# Secrets / TLS material — never commit private keys or PKCS#12 bundles
*.p12
*.pfx
*-key.pem
*.key
